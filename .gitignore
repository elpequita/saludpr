# ============================================
# SaludPR — .gitignore
# ============================================

# --- Secrets & Environment ---
.env
.env.local
.env.*.local
*.pem
*.key
secrets/
credentials.json

# --- Python (backend + etl) ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
.venv/lib/
.venv/lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
venv/
.venv/
env/
ENV/

# --- Node / React (frontend) ---
node_modules/
.pnp
.pnp.js
coverage/
build/
dist/
.next/
out/
.cache/
.parcel-cache/
.vercel

# --- Data (raw & large files) ---
# Raw downloads shouldn't be committed — they're huge and reproducible
data/raw/
data/interim/
*.csv.gz
*.parquet
*.zip
*.shp
*.dbf
*.shx
*.geojson.bak

# Exception: keep small reference files
!data/reference/
!data/processed/README.md

# --- Logs ---
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pip-log.txt

# --- OS / Editor ---
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/
*.iml
.project
.settings/

# --- Database ---
*.sqlite
*.sqlite3
*.db
pgdata/
postgres-data/

# --- Docker ---
.dockerignore

# --- Misc ---
tmp/
temp/
.scratch/
