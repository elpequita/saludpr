# SaludPR Backend — Environment Variables
# Copy this to .env and fill in values. Never commit .env.

# --- Database ---
DATABASE_URL=postgresql+psycopg://saludpr_app:CHANGE_ME@localhost:5432/saludpr

# --- App ---
APP_ENV=development
APP_DEBUG=true
APP_CORS_ORIGINS=http://localhost:5173,https://saludpr.org

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- Rate limiting (if applied at app layer) ---
RATE_LIMIT_PER_MINUTE=120
